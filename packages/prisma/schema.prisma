  createdAt   DateTime @default(now()) @map("created_at")
  createdBy   String   @map("created_by")

  workOrder      WorkOrder       @relation(fields: [workOrderId], references: [id])
  mold           Mold            @relation(fields: [moldId], references: [id])
  vacuumBagTests VacuumBagTest[]

  @@index([workOrderId])
  @@map("layup_logs")
}

// ============================================================================
// v1.2 CFRP — 52. VACUUM BAG TEST
// ============================================================================

model VacuumBagTest {
  id               String  @id @default(cuid())
  workOrderId      String  @map("work_order_id")
  layupLogId       String? @map("layup_log_id")
  passedVacuumMbar Float?  @map("passed_vacuum_mbar")
  result           String  // TestResult: pass | fail
  notes            String?
  testedBy         String  @map("tested_by")

  testedAt  DateTime @map("tested_at")
  createdAt DateTime @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  layupLog  LayupLog? @relation(fields: [layupLogId], references: [id])

  @@index([workOrderId])
  @@map("vacuum_bag_tests")
}

// ============================================================================
// v1.2 CFRP — 53. NDT RESULT
// ============================================================================

model NDTResult {
  id           String  @id @default(cuid())
  workOrderId  String  @map("work_order_id")
  serialNumber String? @map("serial_number")
  method       String  // ultrasound | xray | visual
  defectsFound String? @map("defects_found") // JSON serialized
  result       String  // TestResult: pass | fail
  notes        String?
  testedBy     String  @map("tested_by")

  testedAt  DateTime @map("tested_at")
  createdAt DateTime @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])

  @@index([workOrderId])
  @@map("ndt_results")
}

// ============================================================================
// v1.2 SAFETY — 54. REFLECTIVE FILM ROLL
// ============================================================================

model ReflectiveFilmRoll {
  id            String @id @default(cuid())
  lotId         String @map("lot_id")
  rollNumber    String @map("roll_number")
  materialGrade String @map("material_grade")
  widthMm       Float  @map("width_mm")
  lengthM       Float  @map("length_m")
  status        String @default("available") // available | in_use | consumed | expired

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  version   Int       @default(1)
  createdBy String    @map("created_by")
  updatedBy String    @map("updated_by")

  lot               Lot                @relation(fields: [lotId], references: [id])
  laminationRecords LaminationRecord[]

  @@unique([lotId, rollNumber])
  @@index([status])
  @@map("reflective_film_rolls")
}

// ============================================================================
// v1.2 SAFETY — 55. HOMOLOGATION CERTIFICATE
// ============================================================================

model HomologationCertificate {
  id           String    @id @default(cuid())
  code         String    @unique // E{country}-104R-{seq}/{year}
  itemId       String    @map("item_id")
  authorityRef String?   @map("authority_ref")
  status       String    @default("active") // HomologationStatus
  issuedAt     DateTime  @map("issued_at")
  expiresAt    DateTime  @map("expires_at")
  notes        String?
  plantId      String    @map("plant_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  version   Int       @default(1)
  createdBy String    @map("created_by")
  updatedBy String    @map("updated_by")

  plant Plant @relation(fields: [plantId], references: [id])
  item  Item  @relation(fields: [itemId], references: [id])

  @@index([plantId, status])
  @@index([itemId])
  @@map("homologation_certificates")
}

// ============================================================================
// v1.2 SAFETY — 56. REFLECTANCE TEST
// ============================================================================

model ReflectanceTest {
  id            String  @id @default(cuid())
  workOrderId   String  @map("work_order_id")
  lotId         String? @map("lot_id")
  sampleId      String? @map("sample_id")
  ra            Float? // reflectance coefficient A
  rb            Float? // reflectance coefficient B
  passThreshold Float?  @map("pass_threshold")
  result        String  // TestResult: pass | fail
  notes         String?
  testedBy      String  @map("tested_by")

  testedAt  DateTime @map("tested_at")
  createdAt DateTime @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  lot       Lot?      @relation(fields: [lotId], references: [id])
  sample    Sample?   @relation(fields: [sampleId], references: [id])

  @@index([workOrderId])
  @@map("reflectance_tests")
}

// ============================================================================
// v1.2 SAFETY — 57. COLORIMETRY TEST
// ============================================================================

model ColorimetryTest {
  id          String  @id @default(cuid())
  workOrderId String  @map("work_order_id")
  sampleId    String? @map("sample_id")
  cieL        Float   @map("cie_l")
  cieA        Float   @map("cie_a")
  cieB        Float   @map("cie_b")
  colorClass  String? @map("color_class") // white | yellow | red | amber
  result      String  // TestResult: pass | fail
  notes       String?
  testedBy    String  @map("tested_by")

  testedAt  DateTime @map("tested_at")
  createdAt DateTime @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  sample    Sample?   @relation(fields: [sampleId], references: [id])

  @@index([workOrderId])
  @@map("colorimetry_tests")
}

// ============================================================================
// v1.2 SAFETY — 58. LAMINATION RECORD
// ============================================================================

model LaminationRecord {
  id           String  @id @default(cuid())
  workOrderId  String  @map("work_order_id")
  filmRollId   String  @map("film_roll_id")
  substrateRef String? @map("substrate_ref")
  pressureBar  Float?  @map("pressure_bar")
  tempC        Float?  @map("temp_c")
  speedMmin    Float?  @map("speed_m_min")
  operatorId   String  @map("operator_id")
  notes        String?

  laminatedAt DateTime @map("laminated_at")
  createdAt   DateTime @default(now()) @map("created_at")
  createdBy   String   @map("created_by")

  workOrder WorkOrder          @relation(fields: [workOrderId], references: [id])
  filmRoll  ReflectiveFilmRoll @relation(fields: [filmRollId], references: [id])

  @@index([workOrderId])
  @@map("lamination_records")
}

// ============================================================================
// v1.2 SAFETY — 59. CROSS CUT ADHESION TEST
// ============================================================================

model CrossCutAdhesionTest {
  id          String  @id @default(cuid())
  workOrderId String  @map("work_order_id")
  sampleId    String? @map("sample_id")
  rating      Int // 0-5 scale per ISO 2409
  result      String  // TestResult: pass | fail
  notes       String?
  testedBy    String  @map("tested_by")

  testedAt  DateTime @map("tested_at")
  createdAt DateTime @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  sample    Sample?   @relation(fields: [sampleId], references: [id])

  @@index([workOrderId])
  @@map("cross_cut_adhesion_tests")
}

// ============================================================================
// v1.2 SAFETY — 60. AGING TEST SPECIMEN
// ============================================================================

model AgingTestSpecimen {
  id             String    @id @default(cuid())
  workOrderId    String    @map("work_order_id")
  lotId          String?   @map("lot_id")
  specimenNumber Int       @map("specimen_number")
  agingCondition String    @map("aging_condition") // xenon | thermal | humidity | salt_spray
  scheduledEndAt DateTime  @map("scheduled_end_at")
  status         String    @default("ongoing") // AgingSpecimenStatus
  notes          String?

  startedAt DateTime  @map("started_at")
  endedAt   DateTime? @map("ended_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String    @map("created_by")
  updatedBy String    @map("updated_by")

  workOrder    WorkOrder              @relation(fields: [workOrderId], references: [id])
  lot          Lot?                   @relation(fields: [lotId], references: [id])
  measurements AgingTestMeasurement[]

  @@unique([workOrderId, specimenNumber])
  @@index([status])
  @@map("aging_test_specimens")
}

// ============================================================================
// v1.2 SAFETY — 61. AGING TEST MEASUREMENT
// ============================================================================

model AgingTestMeasurement {
  id                  String  @id @default(cuid())
  agingTestSpecimenId String  @map("aging_test_specimen_id")
  reflectanceRa       Float?  @map("reflectance_ra")
  colorCieL           Float?  @map("color_cie_l")
  colorCieA           Float?  @map("color_cie_a")
  colorCieB           Float?  @map("color_cie_b")
  result              String? // pass | fail | marginal
  notes               String?
  measuredBy          String  @map("measured_by")

  measuredAt DateTime @map("measured_at")
  createdAt  DateTime @default(now()) @map("created_at")

  agingTestSpecimen AgingTestSpecimen @relation(fields: [agingTestSpecimenId], references: [id])

  @@index([agingTestSpecimenId, measuredAt])
  @@map("aging_test_measurements")
}

// ============================================================================
// 62. AUDIT LOG
// ============================================================================

model AuditLog {
  id         String  @id @default(cuid())
  entityType String  @map("entity_type")
  entityId   String  @map("entity_id")
  action     String  // create | update | delete | state_change
  changedBy  String  @map("changed_by")
  before     String? @map("before") // JSON serialized
  after      String? @map("after") // JSON serialized
  ipAddress  String? @map("ip_address")
  userAgent  String? @map("user_agent")
  plantId    String  @map("plant_id")

  changedAt DateTime @default(now()) @map("changed_at")

  plant Plant @relation(fields: [plantId], references: [id])

  @@index([plantId, entityType, entityId])
  @@index([changedBy])
  @@index([changedAt])
  @@map("audit_logs")
}

// ============================================================================
// 63. DOMAIN EVENT
// ============================================================================

model DomainEvent {
  id            String    @id @default(cuid())
  eventType     String    @map("event_type")
  aggregateType String    @map("aggregate_type")
  aggregateId   String    @map("aggregate_id")
  payload       String    @map("payload") // JSON serialized
  occurredAt    DateTime  @default(now()) @map("occurred_at")
  processedAt   DateTime? @map("processed_at")
  plantId       String    @map("plant_id")

  plant Plant @relation(fields: [plantId], references: [id])

  @@index([plantId, aggregateType, aggregateId])
  @@index([occurredAt])
  @@index([eventType])
  @@map("domain_events")
}
