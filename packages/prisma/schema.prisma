  @@unique([plantId, code])
  @@index([equipmentNodeId, status])
  @@index([plannedStart])
  @@map("maintenance_orders")
}

// ============================================================================
// v1.2 — 31. MAINTENANCE LOG
// ============================================================================

model MaintenanceLog {
  id                 String    @id @default(cuid())
  maintenanceOrderId String    @unique @map("maintenance_order_id")
  equipmentNodeId    String    @map("equipment_node_id")
  type               String    // MaintenanceType
  actionsPerformed   String    @map("actions_performed") // JSON serialized
  partsReplaced      String?   @map("parts_replaced") // JSON serialized
  findings           String?
  recommendations    String?
  performedBy        String    @map("performed_by")
  performedAt        DateTime  @map("performed_at")
  durationMinutes    Int?      @map("duration_minutes")

  createdAt DateTime @default(now()) @map("created_at")

  maintenanceOrder MaintenanceOrder @relation(fields: [maintenanceOrderId], references: [id], onDelete: Restrict)
