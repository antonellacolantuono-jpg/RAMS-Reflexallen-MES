# ============================================================================
# Reflexallen MES — Environment Variables Template (DEV MODE — SQLite)
# ============================================================================
#
# COPY THIS FILE TO .env AND ADJUST VALUES FOR YOUR ENVIRONMENT
# DO NOT COMMIT .env TO GIT (it should be in .gitignore)
#
# DEV MODE: This configuration uses SQLite + in-memory cache + local storage.
# No Docker required. See docs/DEV_MODE.md for migration path to production.
# ============================================================================

# ----------------------------------------------------------------------------
# NODE_ENV
# Values: development | staging | production
# ----------------------------------------------------------------------------
NODE_ENV=development

# ============================================================================
# DATABASE — SQLite (DEV MODE)
# ============================================================================
# Prisma datasource provider: sqlite
# File path is relative to packages/prisma/
DATABASE_URL="file:./dev.db"

# ============================================================================
# CACHE — In-memory Map (DEV MODE)
# ============================================================================
# Values: memory | redis (redis requires REDIS_URL)
CACHE_MODE=memory
CACHE_TTL_DEFAULT=300
CACHE_TTL_KPI=600

# ============================================================================
# QUEUE — Synchronous execution (DEV MODE)
# ============================================================================
# Values: sync | bullmq (bullmq requires REDIS_URL)
QUEUE_MODE=sync

# ============================================================================
# STORAGE — Local filesystem (DEV MODE)
# ============================================================================
# Values: local | minio
STORAGE_MODE=local
STORAGE_LOCAL_PATH=./uploads

# ============================================================================
# APPLICATION PORTS
# ============================================================================
API_PORT=3000
WEB_PORT=3001
HMI_PORT=3002

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_SECRET=dev_jwt_secret_change_me_in_production_use_random_32_bytes
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d

ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

SESSION_SECRET=dev_session_secret_change_me

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# FRONTEND CONFIG (Next.js)
# Variables exposed to client must start with NEXT_PUBLIC_
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
NEXT_PUBLIC_APP_NAME=Reflexallen MES
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_DEFAULT_LOCALE=it
NEXT_PUBLIC_FALLBACK_LOCALE=en

# ============================================================================
# REAL-TIME (Socket.IO)
# ============================================================================
SOCKET_IO_PORT=3000
SOCKET_IO_PATH=/socket.io
SOCKET_IO_CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
# Values: error | warn | info | debug | trace

LOG_FORMAT=pretty
# Values: json | pretty (pretty for dev, json for prod)

LOG_OUTPUT=console
# Values: console | file | both

# ============================================================================
# AUDIT & COMPLIANCE (IATF 16949)
# ============================================================================
AUDIT_RETENTION_YEARS=15
AUDIT_LOG_LEVEL=info

# ============================================================================
# DEVICE INTEGRATION (Mock for development)
# ============================================================================
DEVICE_MOCK_ENABLED=true
DEVICE_MOCK_PORT=3100

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_FLUID_POWER_ENABLED=false
FEATURE_DIGITAL_ELECTRICAL_ENABLED=false
FEATURE_PREDICTIVE_MAINTENANCE_ENABLED=false
FEATURE_REAL_DEVICE_INTEGRATION=false
FEATURE_OFFLINE_MODE_ENABLED=true

# ============================================================================
# PAGINATION
# ============================================================================
PAGINATION_DEFAULT_LIMIT=20
PAGINATION_MAX_LIMIT=100

# ============================================================================
# PRISMA STUDIO
# ============================================================================
PRISMA_STUDIO_PORT=5555

# ============================================================================
# PRODUCTION ONLY (set via secret manager — not here)
# ============================================================================
# SENTRY_DSN=https://...@sentry.io/...
# POSTGRES_URL=postgresql://user:pass@host:5432/db
# REDIS_URL=redis://localhost:6379
# MINIO_ENDPOINT=localhost
# MINIO_ACCESS_KEY=...
# MINIO_SECRET_KEY=...
