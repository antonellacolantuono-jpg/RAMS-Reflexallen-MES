# ============================================================================
# Reflexallen MES — apps/api/.env.example
# ============================================================================
# Copy this file to apps/api/.env (NOT committed to git) and adjust values.
# Defaults below match the DEV MODE setup documented in CLAUDE.md.
# ============================================================================

NODE_ENV=development

# DATABASE — relative to packages/prisma/ when run via pnpm scripts.
DATABASE_URL="file:../../packages/prisma/dev.db"

# DEMO MODE — must be 'true' or 'false' in production. Required for the
# mock-device simulators (DEV-LEAK-001 / DEV-CAMERA-001 / DEV-CRIMP-001),
# /api/internal/mock-devices/* endpoints, and /api/internal/fast-forward/*.
# Production builds REFUSE TO BOOT if DEMO_MODE is unset.
DEMO_MODE=true

# Identity fallback for the auto-fired step-execution transitions kicked off
# by the dispatcher (PROMPT_PNE_4_FOCUSED D2, closes TODO-043) and for the
# FastForward debug endpoint (PROMPT_PNE_3 D4). When the request has no JWT
# auth context (DEMO_MODE without login), these env values are used. Both
# must point at real seeded plant + operator IDs for transitions to land.
# Look up via: pnpm --filter @mes/prisma exec prisma studio.
DEMO_USER_ID=
DEMO_PLANT_ID=

# AUTH
JWT_SECRET=dev_jwt_secret_change_me_in_production_use_random_32_bytes
JWT_EXPIRES_IN=8h

# APPLICATION
API_PORT=3000
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# LOGGING
LOG_LEVEL=info
