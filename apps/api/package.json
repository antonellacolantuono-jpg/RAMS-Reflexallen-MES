{
  "name": "@mes/api",
  "version": "0.1.0",
  "private": true,
  "description": "Reflexallen MES API — NestJS",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main",
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@mes/domain": "workspace:*",
    "@mes/prisma": "workspace:*",
    "@mes/schemas": "workspace:*",
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.10",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/platform-socket.io": "^10.3.10",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/websockets": "^10.3.10",
    "argon2": "^0.44.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@mes/config": "workspace:*",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  }
}
