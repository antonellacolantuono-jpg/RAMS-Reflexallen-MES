# ============================================================================
# Reflexallen MES — apps/hmi/.env.local.example
# ============================================================================
# Copy this file to apps/hmi/.env.local (NOT committed to git) and adjust
# values. Next.js apps don't read root .env — per-app .env.local is required.
# ============================================================================

NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# Operator HMI uses DEMO_MODE only to surface UI hints — the auth-gated
# device cycle / parallel slots / recovery flow ship in both modes.
NEXT_PUBLIC_DEMO_MODE=true
