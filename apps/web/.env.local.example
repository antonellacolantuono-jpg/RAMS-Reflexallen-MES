# ============================================================================
# Reflexallen MES — apps/web/.env.local.example
# ============================================================================
# Copy this file to apps/web/.env.local (NOT committed to git) and adjust
# values. Next.js apps don't read root .env — per-app .env.local is required.
# ============================================================================

NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# Gates the back-office /demo Toggle Panel (PROMPT_PNE_3 D2 + D3). When unset
# or 'false', the route returns 404 — non-demo deployments don't ship the JS
# bundle for that page at all.
NEXT_PUBLIC_DEMO_MODE=true
